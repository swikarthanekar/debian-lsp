{
  "name": "coc-debian",
  "version": "0.1.0",
  "description": "Debian language server support for coc.nvim (control, copyright, watch, changelog, tests/control, source/format)",
  "main": "lib/index.js",
  "engines": {
    "coc": "^0.0.80"
  },
  "keywords": [
    "coc.nvim",
    "debian",
    "control",
    "copyright",
    "watch",
    "changelog",
    "deb822"
  ],
  "author": "Your Name",
  "license": "MIT",
  "activationEvents": [
    "onLanguage:debian-control",
    "onLanguage:debian-copyright",
    "onLanguage:debian-watch",
    "onLanguage:debian-changelog",
    "onLanguage:debian-tests-control",
    "onLanguage:debian-source-format"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "coc-debian configuration",
      "properties": {
        "debian.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable debian language server"
        },
        "debian.serverPath": {
          "type": "string",
          "default": "debian-lsp",
          "description": "Path to debian-lsp executable"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/node": "^12.12.0",
    "@types/jest": "^29.0.0",
    "coc.nvim": "^0.0.82",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^4.9.0"
  }
}